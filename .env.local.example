# --- Supabase (projet TCD à créer depuis tcd.technique@gmail.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# SERVICE_ROLE = bypass RLS, JAMAIS exposer côté client
# Utilisée uniquement côté serveur (route handlers /api/admin/*)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Porte A : redirection paiement CB Ten'Up FFT ---
# URL exacte du club à récupérer auprès du bureau TCD
NEXT_PUBLIC_TENUP_URL=https://www.tenup.fft.fr/

# --- Saison en cours (affichée dans le tunnel) ---
NEXT_PUBLIC_SAISON=2026-2027

# --- Contact club (affiché dans le footer + emails) ---
NEXT_PUBLIC_CLUB_EMAIL=contact@tc-davezieux.fr
NEXT_PUBLIC_CLUB_PHONE=

# --- Admin destinataire des notifs de préinscription ---
ADMIN_NOTIF_EMAIL=tcd.technique@gmail.com
